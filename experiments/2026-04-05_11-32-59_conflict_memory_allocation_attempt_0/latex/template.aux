\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Mean throughput improvement versus training length, averaged over agent counts within each layout. Values are percentages relative to the standard decoupled baseline. The dashed vertical line marks the selected 30-epoch checkpoint. Early checkpoints are best in the dense-obstacle layout, while bottleneck performance improves later, illustrating that training length effects are environment dependent and non-monotonic.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:training_improvement_app}{{3}{5}{Mean throughput improvement versus training length, averaged over agent counts within each layout. Values are percentages relative to the standard decoupled baseline. The dashed vertical line marks the selected 30-epoch checkpoint. Early checkpoints are best in the dense-obstacle layout, while bottleneck performance improves later, illustrating that training length effects are environment dependent and non-monotonic}{figure.3}{}}
\newlabel{fig:training_improvement_app@cref}{{[figure][3][]3}{[1][5][]5}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Mean congestion prevention versus training length, averaged over agent counts within each layout. Here prevention means percentage reduction in occupancy-based congestion relative to the standard decoupled baseline; negative values mean CMA produces more congestion. The dashed vertical line marks the selected 30-epoch checkpoint.}}{5}{figure.4}\protected@file@percent }
\newlabel{fig:training_prevention_app}{{4}{5}{Mean congestion prevention versus training length, averaged over agent counts within each layout. Here prevention means percentage reduction in occupancy-based congestion relative to the standard decoupled baseline; negative values mean CMA produces more congestion. The dashed vertical line marks the selected 30-epoch checkpoint}{figure.4}{}}
\newlabel{fig:training_prevention_app@cref}{{[figure][4][]4}{[1][5][]5}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Throughput improvement across training length and agent count. Each cell is the percentage throughput change of CMA relative to the standard decoupled baseline for one layout, checkpoint, and agent count. Sparse layouts stay close to zero, bottleneck layouts show moderate positive regions, and dense-obstacle layouts have the largest upside as well as the largest failures.}}{6}{figure.5}\protected@file@percent }
\newlabel{fig:heat_improvement_app}{{5}{6}{Throughput improvement across training length and agent count. Each cell is the percentage throughput change of CMA relative to the standard decoupled baseline for one layout, checkpoint, and agent count. Sparse layouts stay close to zero, bottleneck layouts show moderate positive regions, and dense-obstacle layouts have the largest upside as well as the largest failures}{figure.5}{}}
\newlabel{fig:heat_improvement_app@cref}{{[figure][5][]5}{[1][5][]6}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Congestion prevention across training length and agent count. Each cell is the percentage reduction in occupancy-based congestion relative to the standard decoupled baseline; negative values indicate worse congestion under CMA. The metric is highly checkpoint sensitive in the bottleneck and dense-obstacle layouts.}}{6}{figure.6}\protected@file@percent }
\newlabel{fig:heat_prevention_app}{{6}{6}{Congestion prevention across training length and agent count. Each cell is the percentage reduction in occupancy-based congestion relative to the standard decoupled baseline; negative values indicate worse congestion under CMA. The metric is highly checkpoint sensitive in the bottleneck and dense-obstacle layouts}{figure.6}{}}
\newlabel{fig:heat_prevention_app@cref}{{[figure][6][]6}{[1][5][]6}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Tradeoff between throughput gain and congestion prevention at the selected 30-epoch checkpoint. Each point is one agent count in one layout, and points are connected only to show progression from 20 to 50 agents. Medium-load settings, especially in bottleneck and dense-obstacle layouts, usually offer the best joint tradeoff, but the relation between the two metrics is not strictly monotone.}}{6}{figure.7}\protected@file@percent }
\newlabel{fig:tradeoff_app}{{7}{6}{Tradeoff between throughput gain and congestion prevention at the selected 30-epoch checkpoint. Each point is one agent count in one layout, and points are connected only to show progression from 20 to 50 agents. Medium-load settings, especially in bottleneck and dense-obstacle layouts, usually offer the best joint tradeoff, but the relation between the two metrics is not strictly monotone}{figure.7}{}}
\newlabel{fig:tradeoff_app@cref}{{[figure][7][]7}{[1][5][]6}{}{}{}}
